MODEL_ONNX_PATH=/app/models/sentiment-onnx
MAX_LENGTH=64
RETURN_SCORES=false
LOG_TIMINGS=false
HOST=0.0.0.0
PORT=8002

# Uvicorn: parallel processes (each loads the ONNX model; scale RAM accordingly).
WORKERS=1

# ONNX Runtime CPU threads (0 intra = runtime default, often all logical cores).
ORT_INTRA_OP_NUM_THREADS=0
ORT_INTER_OP_NUM_THREADS=1

# Optional: limit OpenMP/BLAS threads before inference (useful with cgroup CPU limits).
# OMP_NUM_THREADS=4
