MODEL_ONNX_PATH=/app/models/sentiment-onnx
MAX_LENGTH=64
RETURN_SCORES=false
LOG_TIMINGS=false
HOST=0.0.0.0
PORT=8002

# Target-aware sentiment routing (Redis cache + Gemini escalation)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SENTIMENT_CACHE_TTL_SECONDS=604800
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=4.0
GEMINI_CIRCUIT_THRESHOLD=5
GEMINI_CIRCUIT_WINDOW_SECONDS=60
GEMINI_CIRCUIT_COOLDOWN_SECONDS=120
SENTIMENT_LOW_CONFIDENCE_THRESHOLD=0.6
SENTIMENT_BATCH_ENABLED=0

# OTEL metrics (optional)
OTEL_ENABLED=0
OTEL_OTLP_ENDPOINT=

# Uvicorn: parallel processes (each loads the ONNX model; scale RAM accordingly).
WORKERS=1

# ONNX Runtime CPU threads (0 intra = runtime default, often all logical cores).
ORT_INTRA_OP_NUM_THREADS=0
ORT_INTER_OP_NUM_THREADS=1

# Optional: limit OpenMP/BLAS threads before inference (useful with cgroup CPU limits).
# OMP_NUM_THREADS=4
